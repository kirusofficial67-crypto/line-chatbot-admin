# ===== COPY นี้ไปใส่ใน Vercel Environment Variables =====

# Neon PostgreSQL (จาก neon.tech → Project → Connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://YOUR_APP.vercel.app"
NEXTAUTH_SECRET="สร้างด้วย: openssl rand -base64 32"

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN="ใส่ token ของคุณ"
LINE_CHANNEL_SECRET="ใส่ secret ของคุณ"

# App
APP_URL="https://YOUR_APP.vercel.app"
NODE_ENV="production"
